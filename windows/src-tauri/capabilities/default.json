{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for sand honey where.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://files.dcout.site/**" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://localhost:*/*" }
      ]
    },
    {
      "identifier": "websocket:default",
      "allow": [
        { "url": "wss://files.dcout.site/ws/**" },
        { "url": "ws://127.0.0.1:*/ws/**" },
        { "url": "ws://localhost:*/ws/**" }
      ]
    }
  ]
}
